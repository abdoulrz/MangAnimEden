# --- BASE CONFIGURATION ---
DEBUG=False
SECRET_KEY=your_django_secret_key
DATABASE_URL=postgres://user:password@hostname:5432/manganimeden

# --- EMAIL / SMTP (MANDATORY FOR REGISTRATION) ---
# If EMAIL_HOST is not set, emails will print to the console instead of sending
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=your_long_api_key_from_the_provider
DEFAULT_FROM_EMAIL=MangAnimEden <noreply@manganimeden.net>

# --- AWS / CLOUDFLARE R2 (MEDIA & STATIC) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_ENDPOINT_URL=
AWS_S3_CUSTOM_DOMAIN=

# --- AUTHENTICATION ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ADMIN_BOOTSTRAP_PASSPHRASE=Nefe

# --- CELERY / REDIS ---
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# --- PAYMENT GATEWAYS ---
# FedaPay
FEDAPAY_SECRET_KEY=
FEDAPAY_WEBHOOK_SECRET=
FEDAPAY_ENV=sandbox  # Use 'sandbox' for testing, 'live' for production
FEDAPAY_CALLBACK_URL=https://your-domain.com/users/payment/callback/
